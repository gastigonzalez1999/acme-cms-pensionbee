{
  "rewrites": [
    { "source": "/rss.xml", "destination": "https://acme-cms-api.onrender.com/rss.xml" },
    { "source": "/sitemap.xml", "destination": "https://acme-cms-api.onrender.com/sitemap.xml" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
