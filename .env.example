# API configuration
PORT=3000

# Path to the content directory (absolute or relative to apps/api).
# Default resolves to <repo-root>/content when running from apps/api.
CONTENT_DIR=../../content

# Path to the HTML template.
# Default resolves to <repo-root>/template.html when running from apps/api.
TEMPLATE_PATH=../../template.html

# Comma-separated list of allowed CORS origins (the React SPA's URL).
# IMPORTANT: set this in production — see docs/adr/0008.
CORS_ORIGIN=http://localhost:5173

# Base URL of the deployed web app, used to build absolute URLs in RSS,
# sitemap, and JSON-LD. Set to the Vercel URL in production.
WEB_BASE_URL=http://localhost:5173

# Web app configuration (set in Vercel dashboard for production).
# Must be the full URL of the deployed API (e.g. https://acme-api.onrender.com).
VITE_API_BASE_URL=
